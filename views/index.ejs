								<p>From idea to scalable product, we help you design, develop, and grow digital
									solutions that deliver real results.</p>
							</div>
						</div>
					</div>
					<div class="row upset link-hover shape-num justify-content-center">
						<div class="col-lg-3 col-sm-6 mt30 shape-loc wow fadeInUp" data-wow-delay="0.2s">
							<div class="s-block" data-tilt data-tilt-max="5" data-tilt-speed="1000">
								<div class="s-card-icon"><img src="images/icons/branding.svg"
										alt="SaaS MVP development company" class="img-fluid" />
								</div>
								<h4>MVP <br> Development</h4>
								<p>Launch your product quickly with a scalable MVP built for real users, fast
									validation, and rapid growth.</p>
								<!-- <a href="/service">Learn More <i class="fas fa-chevron-right fa-icon"></i></a> -->
							</div>
						</div>
						<div class="col-lg-3 col-sm-6 mt30 shape-loc wow fadeInUp" data-wow-delay="0.4s">
							<div class="s-block" data-tilt data-tilt-max="5" data-tilt-speed="1000">
								<div class="s-card-icon"><img src="images/icons/development.svg"
										alt="Full stack development agency" class="img-fluid" /></div>
								<h4>AI-Powered Solutions</h4>
								<p>Automate workflows, generate leads, and build smarter systems with AI integrations.
								</p>
								<!-- <a href="/service">Learn More <i class="fas fa-chevron-right fa-icon"></i></a> -->
							</div>
						</div>
						<div class="col-lg-3 col-sm-6 mt30 shape-loc wow fadeInUp" data-wow-delay="0.8s">
							<div class="s-block mb0" data-tilt data-tilt-max="5" data-tilt-speed="1000">
								<div class="s-card-icon"><img src="images/icons/marketing.svg"
										alt="UI UX design company" class="img-fluid" /></div>
								<h4>Web Application Development</h4>
								<p>Automate workflows, generate leads, and build smarter systems with AI integrations.
								</p>
								<!-- <a href="/service">Learn More <i class="fas fa-chevron-right fa-icon"></i></a> -->
							</div>
						</div>
						<div class="col-lg-3 col-sm-6 mt30 shape-loc wow fadeInUp" data-wow-delay="0.8s">
							<div class="s-block mb0" data-tilt data-tilt-max="5" data-tilt-speed="1000">
								<div class="s-card-icon"><img src="images/icons/service1.svg" alt="UI UX design company"
										class="img-fluid" /></div>
								<h4>UI/UX <br> Design</h4>
								<p>Create intuitive, conversion-focused designs that improve user experience and
									engagement.
								</p>
								<!-- <a href="/service">Learn More <i class="fas fa-chevron-right fa-icon"></i></a> -->
							</div>
						</div>
					</div>
					<div class="-cta-btn mt70">
						<div class="free-cta-title v-center wow zoomInDown" data-wow-delay=".9s">
							<p>Hire a <span>Dedicated Developer</span></p>
							<a href="/contact-us" class="btn-main bg-btn2 lnk">Hire Now<i
									class="fas fa-chevron-right fa-icon"></i><span class="circle"></span></a>
						</div>
					</div>
				</div>
			</section>
			<!--End Service-->

			<!--Case Studies-->
			<section class="results-section">
				<div class="container">
					<div class="common-heading mb50">
						<h2 class="mb10">Proven Results from Real Projects</h2>
						<p>We don’t just build — we deliver measurable business outcomes.</p>
					</div>
					<% caseStudies.forEach((item, index)=> { %>
						<div class="case-study wow fadeInUp <%= index % 2 !== 0 ? 'reverse' : '' %>"
							data-wow-delay="<%= index % 2 === 0 ? '0.2s' : '0.8s' %>">
							<!-- IMAGE -->
							<a href="<%= item.link %>" target="_blank" class="browser-frame">

								<div class="case-image">
									<div class="browser-bar">
										<span></span><span></span><span></span>
									</div>

									<img src="<%= item.image %>" alt="<%= item.title %>">
								</div>
							</a>
							<!-- CONTENT -->
							<div class="case-content">
								<div class="case-top">
									<h3>
										<%= item.title %>
									</h3>
									<span class="tag">
										<%= item.category %>
									</span>
								</div>

								<div class="case-block">
									<h4>Problem</h4>
									<p>
										<%= item.problem %>
									</p>
								</div>

								<div class="case-block">
									<h4>Solution</h4>
									<p>
										<%= item.solution %>
									</p>
								</div>

								<div class="case-block result">
									<h4>Result</h4>
									<p>
										<%= item.result %>
									</p>
								</div>
							</div>
						</div>
						<% }) %>
