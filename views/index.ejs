								</div>
								<div class="statnumb">
									<span class="counter">2</span><span>k</span>
									<p>Hours Worked</p>
								</div>
							</div>
						</div>
						<div class="col-lg-3 col-sm-6">
							<div class="statistics mb0">
								<div data-tilt data-tilt-max="20" data-tilt-speed="1000" class="statistics-img">
