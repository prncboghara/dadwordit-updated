<!DOCTYPE html>
<html lang="en" class="no-js">

<head>
	<link rel="preload" as="image" href="images/hero/hero-image-download.png" type="image/png" />
	<link rel="preload" href="images/about/about-image-download.webp" as="image" />

	<style>
		/* GRID OVERLAY (subtle premium feel) */
		.hero-bg-bg1::before {
			content: "";
			position: absolute;
			width: 100%;
			height: 100%;
			background-image: linear-gradient(rgba(20, 1, 1, 0.03) 1px, transparent 1px),
				linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px) !important;
			background-size: 40px 40px !important;
			background-repeat: repeat !important;
			top: 0;
			left: 0;
		}

		.header-heading h1 {
			line-height: 45px !important;
		}

		.bg-btn {
			width: 100% !important;
		}

		.modern-stats-icons {
			display: flex;
			flex-wrap: wrap;
			gap: 15px;
			list-style: none;
			padding: 0;
			margin-top: 25px;
		}

		.modern-stats-icons li {
			padding: 12px 12px;
			border-radius: 12px;
			border: 1px solid lightgray;
			background: rgba(255, 255, 255, 0.6);
			backdrop-filter: blur(10px);
			line-height: 20px !important;
			font-size: 14px !important;
		}

		.info-list-ul li:before {
			content: '' !important;
		}

		.service-section {
			padding-top: 60px !important;
		}

		.clients-modern {
			overflow: hidden;
			margin-top: 40px;
		}

		/* GRID / FLEX */
		.clients-track {
			display: flex;
			flex-wrap: wrap;
			gap: 20px;
			justify-content: center;
			padding: 0;
			list-style: none;
		}

		/* ITEM */
		.client-item {
			flex: 0 0 calc(16.66% - 20px);
		}

		/* CARD STYLE */
		.client-card {
			height: 190px;
			display: flex;
			align-items: center;
			justify-content: center;
			background: white;
			border: 1px solid rgba(0, 0, 0, 0.05);
			transition: all 0.3s ease;
			cursor: pointer;
		}

		/* LOGO STYLE */
		.client-card img {
			filter: grayscale(100%) opacity(0.7);
			transition: all 0.3s ease;
		}

		/* HOVER EFFECT (IMPORTANT) */
		.client-card:hover {
			transform: translateY(-6px) scale(1.03);
			box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
			background: #fff;
		}

		.client-card:hover img {
			filter: grayscale(0%) opacity(1);
		}

		/* RESPONSIVE */
		@media (max-width: 992px) {
			.client-item {
				flex: 0 0 calc(25% - 20px);
			}
		}

		@media (max-width: 600px) {
			.client-item {
				flex: 0 0 calc(50% - 20px);
			}
		}

		/* NEW SECTION */
		.browser-frame {
			overflow: hidden;
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
			background: #fff;
			border-radius: 12px;
		}

		.browser-bar {
			height: 35px;
			background: #f3f4f6;
			display: flex;
			align-items: center;
			padding: 0 10px;
			gap: 6px;
		}

		.browser-bar span {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: #d1d5db;
		}


		/* CASE STUDY LAYOUT */
		.case-study {
			display: grid;
			grid-template-columns: 1.1fr 1fr;
			gap: 60px;
			align-items: center;
			margin-bottom: 100px;
		}

		.case-study.reverse .browser-frame {
			order: 2;
		}

		/* IMAGE */
		.case-image {
			position: relative;
		}

		.case-image img {
			width: 100%;
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
		}

		/* CONTENT */
		.case-top {
			display: flex;
			align-items: center;
			gap: 12px;
			margin-bottom: 20px;
		}

		.case-top h3 {
			font-size: 24px;
		}

		.tag {
			font-size: 12px;
			background: #eef2ff;
			color: #4f46e5;
			padding: 4px 10px;
			border-radius: 999px;
		}

		/* BLOCKS */
		.case-block {
			margin-bottom: 18px;
		}

		.case-block h4 {
			font-size: 14px;
			color: #9ca3af;
			margin-bottom: 4px;
			text-transform: uppercase;
			letter-spacing: 0.5px;
		}

		.case-block p {
			font-size: 15px;
			color: #374151;
		}

		/* RESULT HIGHLIGHT */
		.case-block.result {
			background: #f0fdf4;
			padding: 12px 16px;
			border-radius: 8px;
		}

		.case-block.result p {
			color: #166534;
			font-weight: 500;
		}

		/* RESPONSIVE */
		@media (max-width: 900px) {
			.case-study {
				grid-template-columns: 1fr;
				gap: 30px;
			}

			.case-study.reverse .case-image {
				order: 0;
			}

		}
	</style>
</head>


<%- include ('partials/head', {title, meta, og, twitter, schema, trackingId}) %>

	<body>
		<!--Start Preloader -->
		<div class="onloadpage" id="page_loader">
			<div class="pre-content">
				<div class="logo-pre"><img src="images/logo.webp" alt="Logo" class="img-fluid" /></div>
				<div class="pre-text- text-radius text-light text-animation bg-b">Loading your experience</div>
			</div>
		</div>
		<!--End Preloader -->

		<!--Start Header -->
		<%- include ('partials/header') %>
			<!--End Header -->

			<!--Start Hero-->
			<section class="hero-section hero-bg-bg1">
				<div class="text-block">
					<div class="container">
						<div class="row">
							<div class="col-lg-6 v-center">
								<div class="header-heading">
									<h1 class="wow fadeInUp" data-wow-delay=".2s">Build & Launch Your SaaS Faster —
										Without Hiring an In-House Team</h1>
									<p class="wow fadeInUp" data-wow-delay=".4s">We help startups design, develop, and
										scale SaaS products — from MVP to full platform — with fast execution, clean
										architecture, and real business results.</p>
									<a href="/contact-us"
										class="btn-br bg-btn3 btshad-b2 btn-main bg-btn lnk wow fadeInUp"
										data-wow-delay=".6s">Get Your Free Project Strategy <i
											class="fas fa-chevron-right fa-icon"></i><span class="circle"></span></a>
									<ul class="info-list-ul modern-stats-icons wow fadeInUp" data-wow-delay=".8s">
										<li>5+ Years Building Scalable Products</li>
										<li>50+ Projects Successfully Delivered</li>
										<li>Trusted by 20+ Businesses</li>
										<li>Reliable Support When You Need It</li>
									</ul>
								</div>
							</div>
							<div class="col-lg-6 v-center">
								<div class="single-image wow fadeIn" data-wow-delay=".5s">
									<img src="images/hero/hero2.svg"
