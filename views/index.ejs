									<div class="item-image" data-tilt data-tilt-max="2" data-tilt-speed="1000">
										<a href="/our-work" target="_blank">
											<img src="<%= item.portfolioImg %>" alt="<%= item.sortTitle %>"
												class="img-fluid" />
										</a>
