<style>
    .custom-form-container {
        max-width: 900px;
        margin: auto;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .form-group {
        position: relative;
        width: 100%;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        border: none;
        border-bottom: 2px solid #cbd5e1;
        outline: none;
        padding: 10px 5px;
        font-size: 16px;
        background: transparent;
    }

    .form-group textarea {
        resize: none;
    }

    .form-group label {
        position: absolute;
        top: 10px;
        left: 5px;
        font-size: 14px;
        color: #64748b;
        pointer-events: none;
        transition: 0.3s ease;
    }

    /* Floating effect */
    .form-group input:focus+label,
    .form-group input:not(:placeholder-shown)+label,
    .form-group textarea:focus+label,
    .form-group textarea:not(:placeholder-shown)+label,
    .form-group select:focus+label,
    .form-group select:valid+label {
        top: -10px;
        font-size: 12px;
        color: #7e54f8;
    }

    /* Bottom line focus */
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
        border-bottom: 2px solid #7e54f8;
    }

    /* Full width textarea */
    .full-width {
        grid-column: span 2;
    }

    /* Button */
    .submit-btn {
        margin-top: 30px;
    }

    /* 📱 Responsive */
    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .full-width {
            grid-column: span 1;
        }
    }

    .form-message {
        margin-top: 20px;
        padding: 12px 16px;
        border-radius: 6px;
        font-size: 14px;
        display: none;
        transition: all 0.3s ease;
    }

    .form-message.success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #10b981;
    }

    .form-message.error {
        background: #fef2f2;
        color: #7f1d1d;
        border: 1px solid #ef4444;
        height: 100% !important;
    }

    /* Button Loader */
    .submit-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-loader {
        width: 18px;
        height: 18px;
        border: 2px solid white;
        border-top: 2px solid transparent;
        border-radius: 50%;
        display: none;
        animation: spin 0.6s linear infinite;
    }

    .submit-btn.loading .btn-loader {
        display: inline-block;
    }

    .submit-btn.loading .btn-text {
        opacity: 0.7;
    }

    .submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>
</head>
<div class="custom-form-container">
    <form id="customForm">
        <div class="form-grid">
            <div class="form-group">
                <input type="text" name="full_name" placeholder=" " required />
                <label>Full Name*</label>
            </div>

            <div class="form-group">
                <input type="email" name="email" placeholder=" " required />
                <label>Email Address*</label>
            </div>

            <div class="form-group">
                <input type="text" name="phone" placeholder=" " />
                <label>Phone / WhatsApp</label>
            </div>

            <div class="form-group">
                <select name="service" required>
                    <option value="" disabled selected hidden></option>
                    <option>MVP Development</option>
                    <option>AI-powered MVP</option>
                    <option>Web Development</option>
                    <option>UI/UX Design</option>
                    <option>Something else</option>
                </select>
                <label>What are you looking to build?*</label>
            </div>

            <div class="form-group full-width">
                <textarea name="message" placeholder=" " required></textarea>
                <label>Briefly describe your project*</label>
            </div>
        </div>

        <div id="formMessage" class="form-message"></div>

        <button type="submit" class="submit-btn btn-br bg-btn3 btshad-b2 btn-main bg-btn lnk">
            <span class="btn-text">Submit</span>
            <span class="btn-loader"></span>
        </button>
    </form>
</div>

<script>
document.getElementById("customForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const form = this;
    const messageBox = document.getElementById("formMessage");
    const button = form.querySelector(".submit-btn");

    // 🔄 Start Loader
    button.classList.add("loading");
    button.disabled = true;

    const formData = new URLSearchParams();
    formData.append("fullName", form.full_name.value);
    formData.append("email", form.email.value);
    formData.append("phone", form.phone.value);
    formData.append("projectType", form.service.value);
    formData.append("description", form.message.value);

    try {
        const res = await fetch("https://n8n.dadwordit.com/webhook/contact-us", {
            method: "POST",
            headers: {
                "X-API-KEY": "xapi_8f3Kx9LmP2qR7sVwYzA1BcD4EfGhIjKlMnOpQrStUvWxYz12",
                "Content-Type": "application/x-www-form-urlencoded"
            },
            body: formData
        });

        if (!res.ok) throw new Error("Failed");

        // ✅ Success Message (Better UX)
        messageBox.style.display = "block";
        messageBox.className = "form-message success";
        messageBox.innerHTML = `Thanks for reaching out. Our team will contact you within 24 hours.`;

        form.reset();

    } catch (err) {
        console.error(err);

        // ❌ Error Message
        messageBox.style.display = "block";
        messageBox.className = "form-message error";
        messageBox.innerHTML = `
            ❌ <strong>Oops! Something went wrong.</strong><br>
            Please try again or contact us directly.
        `;
    }

    // 🛑 Stop Loader
    button.classList.remove("loading");
    button.disabled = false;

    // ⏳ Auto hide
    setTimeout(() => {
        messageBox.style.display = "none";
    }, 8000);
});
</script>