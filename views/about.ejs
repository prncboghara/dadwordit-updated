					window.addEventListener("load", function () {
						const script = document.createElement("script");
						script.src = "https://js.hsforms.net/forms/embed/v2.js";
						script.charset = "utf-8";
						script.onload = function () {
							hbspt.forms.create({
								portalId: "46121436",
