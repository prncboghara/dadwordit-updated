         <script>
            // Add the following code if you want the name of the file appear on select
            $(".custom-file-input").on("change", function () {
               var fileName = $(this).val().split("\\").pop();
               $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
            });
         </script>
         <script>
            const SHEET_URL = "https://docs.google.com/spreadsheets/d/1BDnfKov1N5hjxalZz7PaJy9J_UMgk2zjYfxVQGxcNd4/gviz/tq?tqx=out:json";

            fetch(SHEET_URL)
               .then(response => response.text())
               .then(data => {
                  // Parse the response to JSON
                  const json = JSON.parse(data.substring(47).slice(0, -2));
                  const rows = json.table.rows;

                  // Map job data
                  const jobList = rows.map(row => ({
                     title: row.c[0]?.v,
                     num_of_posts: row.c[1]?.v,
                     description: row.c[2]?.v,
                     required_skills: row.c[3]?.v,
                     required_experience: row.c[4]?.v,
                     location: row.c[5]?.v,
                     job_type: row.c[6]?.v,
                     applyLink: row.c[7]?.v
                  }));

                  // Display jobs on the page
                  const jobContainer = document.getElementById("accordionExample");
                  // console.log("jobList", jobList)
                  jobList.forEach((job, i) => {
                     const skills = job.required_skills.split(',');
                     let skill_ele = ''
                     skills.forEach(skill => {
                        skill_ele += `<li>${skill}</li>`
                     })

                     const element = `
                  <div class="accordion-item">
                     <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-${i}" aria-expanded="true" aria-controls="collapseOne">
                           ${job.title} - ${job.num_of_posts} Post
                        </button>
                     </h2>
                     <div id="collapse-${i}" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                        <div class="accordion-body">
                           <div class="data-reqs">
                              <h5 class="pt20 pb20">Overview</h5>
                              <p>${job.description}</p>
                              <h5 class="pt20 pb20">Required experience</h5>
                              <p>${job.required_experience}</p>
                              <h4 class="pb20 pt20">Skills Required:</h4>
                              <ul class="list-ul ul-check">
                                 ${skill_ele}
                              </ul>
                              <a href="${job.applyLink}" class="btn-main bg-btn3 lnk mt20" target="_blank">Apply Now<i class="fas fa-chevron-right fa-icon"></i><span class="circle"></span></a>
                           </div>
                        </div>
                     </div>
                  </div>
               `;
                     jobContainer.innerHTML += element;
                  });
               })
               .catch(err => console.error("Error loading jobs:", err));

         </script>
